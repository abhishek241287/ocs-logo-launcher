{
  "expo": {
    "name": "OCS OORJA Launcher",
    "slug": "company-logo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ocs-logo.jpg",
    "scheme": "ocsoorja",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/ocs-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F7F9FC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.ocs.oorja.launcher"
    },
    "android": {
      "package": "in.ocs.oorja.launcher",
      "backgroundColor": "#F7F9FC",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F9FC"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.QUERY_ALL_PACKAGES"
      ],
      "intentFilters": [
        {
          "action": "MAIN",
          "category": [
            "HOME",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow OCS OORJA Launcher to access your photos.",
          "savePhotosPermission": "Allow OCS OORJA Launcher to save wallpaper photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow OCS OORJA Launcher to access your photos to set wallpaper."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
